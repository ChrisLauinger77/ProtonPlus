msgstr "Spiel bearbeiten"

#: src/widgets/games/games-row.vala:122
msgid "Launch custom executable"
msgstr "Benutzerdefinierte ausführbare Datei starten"

#: src/widgets/games/games-row.vala:129
msgid "Launch game"
msgstr "Spiel starten"

#: src/widgets/games/games-row.vala:134
msgid "Browse game install directory"
msgstr "Installationsverzeichnis des Spiels durchsuchen"

#: src/widgets/games/games-row.vala:140
msgid "Browse prefix directory"
msgstr "Präfixverzeichnis durchsuchen"

#: src/widgets/games/games-row.vala:160
msgid "Select executable"
msgstr "Ausführbare Datei auswählen"

#: src/widgets/games/games-row.vala:168
msgid "Executables (*.exe, *.msi, *.msu, *.bat)"
msgstr "Ausführbare Dateien (*.exe, *.msi, *.msu, *.bat)"

#: src/widgets/games/games-row.vala:215
msgid "Compatibility Tool Not Found"
msgstr "Kompatibilitätswerkzeug nicht gefunden"

#: src/widgets/games/games-row.vala:216
#, c-format
msgid "The compatibility tool required for %s is missing from your system. Please ensure it is correctly installed."
msgstr "Das für %s benötigte Kompatibilitätswerkzeug fehlt auf Ihrem System. Bitte stellen Sie sicher, dass es korrekt installiert ist."

#: src/widgets/games/games-tool-row.vala:18 src/widgets/tools/tools-migrate-box.vala:18
msgid "New tool"
msgstr "Neues Werkzeug"

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:14
msgid "Advanced options"
msgstr "Erweiterte Optionen"

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:15
msgid "Extra control over the final Steam launch command."
msgstr "Zusätzliche Kontrolle über den endgültigen Steam-Startbefehl."

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:17
msgid "Appends Steam's game command."
msgstr "Fügt den Steam-Spielbefehl an."

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:19
msgid "Additional arguments"
msgstr "Weitere Argumente"

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:19
msgid "Add extra launch options"
msgstr "Zusätzliche Startoptionen hinzufügen"

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:24
msgid "Custom launch arguments"
msgstr "Benutzerdefinierte Startparameter"

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:24
msgid "Add your own launch options."
msgstr "Füge deine eigenen Startoptionen hinzu."

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:14
msgid "Audio options"
msgstr "Audiooptionen"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:15
msgid "Audio-related launch options."
msgstr "Audio-bezogene Startoptionen."

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:18
msgid "PulseAudio low latency"
msgstr "PulseAudio mit niedriger Latenz"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:19
msgid "Enables low latency mode in PulseAudio which can reduce audio latency in some games (60, 90, 120)."
msgstr "Aktiviert den Niedriglatenzmodus in PulseAudio, der die Audiolatenz in manchen Spielen reduzieren kann (60, 90, 120)."

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:20
msgid "MSEC"
msgstr "MSEC"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:27 src/widgets/games/launch-options-editor/launch-options-editor-aco-debug.vala:11
#: src/widgets/games/launch-options-editor/launch-options-editor-dll-overrides.vala:36 src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:11
#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:11 src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:26
msgid "Disabled"
msgstr "Deaktiviert"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:38
msgid "WINEALSA Channels"
msgstr "WINEALSA-Kanäle"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:39
msgid "Sets the number of ALSA output channels used by Wine. Available from GE-Proton11-1."
msgstr "Legt die Anzahl der von Wine verwendeten ALSA-Ausgabekanäle fest. Verfügbar ab GE-Proton11-1."

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:52
msgid "WINEALSA Spatial Audio"
msgstr "WINEALSA-Raumklang"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:53
msgid "Enables spatial mixing in Wine ALSA audio output. Requires WINEALSA Channels set to 4, 6, or 8. Available from GE-Proton11-1."
msgstr "Aktiviert die räumliche Abmischung in der Wine-ALSA-Audioausgabe. Erfordert, dass WINEALSA-Kanäle auf 4, 6 oder 8 eingestellt sind. Verfügbar ab GE-Proton11-1."

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:13
msgid "Common options"
msgstr "Häufige Optionen"

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:14
msgid "Quick toggles for the launch options people reach for most often."
msgstr "Schnellzugriffstasten für die Startoptionen, die am häufigsten genutzt werden."

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:17
msgid "Performance overlay"
msgstr "Leistungsübersicht"

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:18
msgid "Shows an in-game overlay with FPS, CPU/GPU usage, and temps."
msgstr "Zeigt ein Overlay im Spiel mit FPS, CPU-/GPU-Auslastung und Temperaturen an."

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:31
msgid "Disable Steam Deck Mode"
msgstr "Steam-Deck-Modus deaktivieren"

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:32
msgid "Disables the Steam Deck-specific profile that some games use."
msgstr "Deaktiviert das Steam-Deck-spezifische Profil, das von einigen Spielen verwendet wird."

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:37
msgid "Wayland"
msgstr "Wayland"

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:38
msgid "Runs the game natively on Wayland instead of through XWayland but it breaks Steam Input and the Steam Overlay."
msgstr "Das Spiel läuft nativ unter Wayland statt über XWayland, allerdings funktionieren Steam Input und das Steam-Overlay dann nicht mehr."

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:43 src/widgets/preferences/preferences-dialog.vala:348
msgid "Feral Gamemode"
msgstr "Feral GameMode"

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:44
msgid "Requests temporary optimizations for system performance (CPU governor, process priority) when the game is running."
msgstr "Fordert während der Ausführung des Spiels vorübergehende Optimierungen der Systemleistung an (CPU-Regelung, Prozesspriorität)."

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:12
msgid "DXVK options"
msgstr "DXVK-Optionen"

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:13 src/widgets/games/launch-options-editor/groups/more-options-group.vala:20
#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:14
msgid "Extra graphics settings and launch behaviors."
msgstr "Zusätzliche Grafikeinstellungen und Startverhalten."

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:16
msgid "DXVK Async"
msgstr "DXVK Async"

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:17
msgid "Enables DXVK's asynchronous pipeline compilation which can reduce stuttering."
msgstr "Aktiviert die asynchrone Pipeline-Kompilierung von DXVK, wodurch Ruckler reduziert werden können."

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:21
msgid "Disable DXVK logging"
msgstr "DXVK-Protokollierung deaktivieren"

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:22
msgid "Sets DXVK's log level to none which can improve performance in some games."
msgstr "Setzt die DXVK-Protokollstufe auf „none“, was die Leistung in einigen Spielen verbessern kann."

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:26
msgid "DXVK Frame Limit"
msgstr "DXVK-Bildbegrenzung"

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:27
msgid "Caps the frame rate using DXVK's built-in frame limiter."
msgstr "Begrenzt die Bildrate mit dem integrierten Bildratenbegrenzer von DXVK."

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:28 src/widgets/games/launch-options-editor/wrappers/gamescope.vala:42
#: src/widgets/games/launch-options-editor/wrappers/scopebuddy.vala:53
msgid "FPS"
msgstr "FPS"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:14
msgid "Game arguments"
msgstr "Spielargumente"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:15
msgid "Flags passed directly to the game."
msgstr "Flags, die direkt an das Spiel übergeben werden."

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:18
msgid "Skip launcher"
msgstr "Launcher überspringen"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:19
msgid "Adds -skip-launcher to bypass launchers in games that support it."
msgstr "Fügt „-skip-launcher“ hinzu, um den Startbildschirm in Spielen zu umgehen, die dies unterstützen."

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:22 src/widgets/mangohud/mangohud-performance-page.vala:44
msgid "Vulkan"
msgstr "Vulkan"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:22
msgid "Adds -vulkan to make the game use its Vulkan renderer."
msgstr "Fügt „-vulkan“ hinzu, damit das Spiel den Vulkan-Renderer verwendet."

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:23
msgid "DirectX 11"
msgstr "DirectX 11"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:23
msgid "Adds -dx11 to make the game use its DirectX 11 renderer."
msgstr "Fügt -dx11 hinzu, damit das Spiel den DirectX-11-Renderer verwendet."

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:24
msgid "DirectX 12"
msgstr "DirectX 12"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:24
msgid "Adds -dx12 to make the game use its DirectX 12 renderer."
msgstr "Fügt -dx12 hinzu, damit das Spiel den DirectX 12-Renderer verwendet."

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:25
msgid "Console"
msgstr "Konsole"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:25
msgid "Adds -console to open the game's developer console when supported."
msgstr "Fügt „-console“ hinzu, um die Entwicklerkonsole des Spiels zu öffnen, sofern dies unterstützt wird."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:23
msgid "Mesa Anti-Lag"
msgstr "Mesa Anti-Lag"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:23
msgid "Reduces latency on supported AMD Mesa setups."
msgstr "Reduziert die Latenz bei unterstützten AMD-Mesa-Konfigurationen."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:24
msgid "Use dGPU"
msgstr "Verwende dGPU"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:24
msgid "Makes the game use the AMD dGPU on hybrid systems."
msgstr "Stellt sicher, dass das Spiel auf Hybrid-Systemen die AMD-Grafikkarte nutzt."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:26
msgid "Hide AMD APU"
msgstr "AMD APU ausblenden"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:27
msgid "Makes Proton report an AMD APU as a discrete GPU for games that mis-detect integrated graphics."
msgstr "Bewirkt, dass Proton eine AMD-APU in Spielen, die integrierte Grafikkarten falsch erkennen, als diskrete GPU meldet."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:31
msgid "FSR 4 Upgrade"
msgstr "FSR 4-Upgrade"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:32
msgid "Upgrades FSR 3.1 to FSR 4 in supported games. This option also disables AMD Anti-Lag 2 currently due to various issues."
msgstr "Aktualisiert FSR 3.1 auf FSR 4 in unterstützten Spielen. Diese Option deaktiviert derzeit aufgrund verschiedener Probleme auch AMD Anti-Lag 2."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:39
msgid "FSR 4 RDNA3 Upgrade"
msgstr "FSR 4 RDNA3-Upgrade"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:39
msgid "Optimizes FSR 4.0 for RDNA3 hardware."
msgstr "Optimiert FSR 4.0 für RDNA3-Hardware."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:45
msgid "Staging shared memory"
msgstr "Staging Shared Memory"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:46
msgid "Enables shared memory support in the AMD GPU driver for better performance in some games."
msgstr "Aktiviert die Unterstützung für gemeinsam genutzten Speicher im AMD-GPU-Treiber, um die Leistung in einigen Spielen zu verbessern."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:50
msgid "Mesa GLThread"
msgstr "Mesa GLThread"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:51
msgid "Enables Mesa's GLThread optimization for better performance in some games."
msgstr "Aktiviert Mesas GLThread-Optimierung, um die Leistung in einigen Spielen zu verbessern."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:56
msgid "Disable Mesa shader cache"
msgstr "Mesa-Shader-Cache deaktivieren"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:57
msgid "Disables Mesa's shader cache which can cause stuttering in some games."
msgstr "Deaktiviert Mesas Shader-Cache, der in manchen Spielen Ruckler verursachen kann."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:78
msgid "Configure RADV debug options for troubleshooting and performance testing."
msgstr "Konfiguriert RADV-Debug-Optionen zur Fehlerbehebung und für Leistungstests."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:80
msgid "Configure RADV performance test options for testing experimental driver features. Use with caution as these features can cause instability or other issues."
msgstr "RADV-Leistungstestoptionen zum Testen experimenteller Treiberfunktionen konfigurieren. Mit Vorsicht verwenden, da diese Funktionen Instabilität oder andere Probleme verursachen können."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:83
msgid "Select which AMD Vulkan driver to use. This can be used to switch between RADV and AMD's official Vulkan driver on supported systems."
msgstr "Wählen Sie aus, welcher AMD-Vulkan-Treiber verwendet werden soll. Damit kann auf unterstützten Systemen zwischen RADV und AMDs offiziellem Vulkan-Treiber gewechselt werden."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:86
msgid "Configure ACO compiler debug options to troubleshoot shader compilation issues, fix in-game stuttering, or analyze graphics performance. Use with caution."
msgstr "ACO-Compiler-Debug-Optionen konfigurieren, um Shader-Kompilierungsprobleme zu beheben, Ruckler im Spiel zu verringern oder die Grafikleistung zu analysieren. Mit Vorsicht verwenden."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-intel-options-group.vala:10
msgid "XeSS Upgrade"
msgstr "XeSS-Upgrade"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-intel-options-group.vala:10
msgid "Upgrades XeSS in supported games."
msgstr "Aktiviert XeSS in unterstützten Spielen."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:18
msgid "NVAPI"
msgstr "NVAPI"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:18
msgid "Lets games access NVIDIA-specific features like DLSS."
msgstr "Ermöglicht Spielen den Zugriff auf NVIDIA-spezifische Funktionen wie DLSS."

#. gpu_vendor_bindings.append (new LaunchOptionBinding ({ "PROTON_ENABLE_NVAPI=1" }, nvapi_tile.toggle));
#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:24
msgid "Update DLSS components"
msgstr "DLSS-Komponenten aktualisieren"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:25
msgid "Auto upgrades DLSS components for supported games."
msgstr "Auto aktualisiert die DLSS-Komponenten für unterstützte Spiele."

#. gpu_vendor_bindings.append (new LaunchOptionBinding ({ "PROTON_ENABLE_NGX_UPDATER=1" }, nvidia_ngx_updater_tile.toggle));
#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:33
msgid "Hide NVIDIA GPU"
msgstr "NVIDIA-GPU ausblenden"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:34
msgid "Makes Proton report an NVIDIA GPU as AMD for games that expect Windows-only NVIDIA driver behavior."
msgstr "Bewirkt, dass Proton eine NVIDIA-GPU als AMD meldet, wenn es um Spiele geht, die ein für Windows-exklusive NVIDIA-Treiber typisches Verhalten erwarten."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:37
msgid "DLSS Indicator"
msgstr "DLSS-Anzeige"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:37
msgid "Shows a DLSS status indicator in-game."
msgstr "Zeigt im Spiel eine DLSS-Statusanzeige an."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:39
msgid "NVIDIA Libraries"
msgstr "NVIDIA-Bibliotheken"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:40
msgid "Enables NVIDIA-specific libraries (PhysX, CUDA). This is not needed for DLSS or ray tracing."
msgstr "Aktiviert NVIDIA-spezifische Bibliotheken (PhysX, CUDA). Dies ist für DLSS oder Raytracing nicht erforderlich."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-options-group.vala:23
msgid "GPU vendor options"
msgstr "Auswahl an GPU-Anbietern"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-options-group.vala:27
msgid "Use GPU-specific compatibility toggles for AMD, NVIDIA and Intel hardware."
msgstr "Verwenden Sie GPU-spezifische Kompatibilitätsschalter für AMD-, NVIDIA- und Intel-Hardware."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-options-group.vala:53
msgid "AMD"
msgstr "AMD"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-options-group.vala:54
msgid "NVIDIA"
msgstr "NVIDIA"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-options-group.vala:55
msgid "Intel"
msgstr "Intel"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:19
msgid "More options"
msgstr "Weitere Optionen"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:22
msgid "VKBasalt"
msgstr "VKBasalt"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:22
msgid "Adds visual effects like sharpening and color adjustments."
msgstr "Fügt visuelle Effekte wie Schärfen und Farbanpassungen hinzu."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:24
msgid "WineD3D"
msgstr "WineD3D"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:25
msgid "Uses OpenGL instead of Vulkan. Only enable if you're having DXVK issues."
msgstr "Verwendet OpenGL anstelle von Vulkan. Nur aktivieren, wenn Probleme mit DXVK auftreten."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:30
msgid "Use FSync"
msgstr "FSync verwenden"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:31
msgid "Uses FSync instead of NTSync. Can fix issues in certain games that do not pair well with NTSync."
msgstr "Verwendet FSync anstelle von NTSync. Kann Probleme in bestimmten Spielen beheben, die mit NTSync nicht gut zusammenarbeiten."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:36
msgid "Local shader cache"
msgstr "Lokaler Shader-Cache"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:37
msgid "Enables per-game shader cache. This isolates the shader cache of each game but does not compile them ahead-of-time."
msgstr "Aktiviert den Shader-Cache pro Spiel. Dadurch wird der Shader-Cache jedes Spiels isoliert, die Shader werden jedoch nicht vorab kompiliert."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:41
msgid "Prefer SDL controller"
msgstr "Bevorzugt SDL-Controller"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:41
msgid "Workaround for controller detection issues."
msgstr "Abhilfe bei Problemen mit der Controller-Erkennung."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:43
msgid "Disable Steam Input"
msgstr "Steam Input deaktivieren"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:44
msgid "Disables Steam Input support. Fixes Wayland controller/gamepad issues."
msgstr "Deaktiviert die Steam-Input-Unterstützung. Behebt Probleme mit Wayland-Controllern und Gamepads."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:48
msgid "WINE_VK_USE_SYNC2"
msgstr "WINE_VK_USE_SYNC2"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:49
msgid "Enables WINE_VK_USE_SYNC2 which can improve performance and reduce stuttering in some games when using WineD3D."
msgstr "Aktiviert WINE_VK_USE_SYNC2, wodurch sich bei Verwendung von WineD3D die Leistung verbessern und Ruckeln reduzieren kann."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:53
msgid "WINE_SYNC_USE_FUTEX_WAITV"
msgstr "WINE_SYNC_USE_FUTEX_WAITV"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:54
msgid "Enables WINE_SYNC_USE_FUTEX_WAITV which can improve performance and reduce stuttering in some games when using WineD3D."
msgstr "Aktiviert WINE_SYNC_USE_FUTEX_WAITV, wodurch sich bei Verwendung von WineD3D die Leistung verbessern und Ruckeln reduzieren kann."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:58
msgid "Simulate Write-Copy Memory"
msgstr "Write-Copy-Speicher simulieren"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:59
msgid "Forces Wine to simulate page-write protection, fixing initialization errors in certain older titles."
msgstr "Zwingt Wine, den Seitenschreibschutz zu simulieren, wodurch Initialisierungsfehler in bestimmten älteren Titeln behoben werden."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:18
msgid "Proton options"
msgstr "Proton-Optionen"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:19
msgid "Extra Proton settings and launch behaviors."
msgstr "Zusätzliche Proton-Einstellungen und Startverhalten."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:22
msgid "Higher priority for games"
msgstr "Höhere Priorität für Spiele"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:23
msgid "Gives the game a higher CPU priority which can improve performance in some cases."
msgstr "Weist dem Spiel eine höhere CPU-Priorität zu, wodurch sich die Leistung in einigen Fällen verbessern kann."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:27
msgid "Use WoW64"
msgstr "WoW64 verwenden"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:28
msgid "Enables WoW64 support for 32-bit games on 64-bit Proton builds. This can improve compatibility for some older games."
msgstr "Aktiviert die WoW64-Unterstützung für 32-Bit-Spiele mit 64-Bit-Proton-Builds. Dies kann die Kompatibilität einiger älterer Spiele verbessern."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:32
msgid "Allows 32-bit games to use more than 2GB of RAM"
msgstr "Ermöglicht 32-Bit-Spielen, mehr als 2 GB RAM zu verwenden"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:33
msgid "Forces 32-bit games to use large address aware which can improve performance and stability."
msgstr "Zwingt 32-Bit-Spiele zur Verwendung von Large Address Aware, wodurch sich Leistung und Stabilität verbessern können."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:37
msgid "Enable Proton logs"
msgstr "Proton-Protokolle aktivieren"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:38
msgid "Enables logging for Proton which can help with troubleshooting game issues. Logs are saved in the game's compatibility data folder."
msgstr "Aktiviert die Protokollierung für Proton, die bei der Fehlerbehebung von Spielproblemen helfen kann. Protokolle werden im Kompatibilitätsdatenordner des Spiels gespeichert."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:42
msgid "Enable Proton OptiScaler"
msgstr "Proton OptiScaler aktivieren"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:43
msgid "Enables the Proton OptiScaler which can improve performance and image quality for some games (Available from version 11-1)."
msgstr "Aktiviert Proton OptiScaler, wodurch sich Leistung und Bildqualität einiger Spiele verbessern können (verfügbar ab Version 11-1)."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:47
msgid "Enable Proton Discord Bridge"
msgstr "Proton Discord Bridge aktivieren"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:48
msgid "Enables the Proton Discord Bridge which can improve integration with Discord for some games (Available from version 11-1)."
msgstr "Aktiviert Proton Discord Bridge, wodurch sich die Discord-Integration einiger Spiele verbessern kann (verfügbar ab Version 11-1)."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:52
msgid "Use D7VK"
msgstr "D7VK verwenden"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:53
msgid "Enables the use of D7VK which can improve performance and compatibility for some Direct3D 9 games (Available from version 11-1)."
msgstr "Aktiviert die Verwendung von D7VK, wodurch sich bei einigen Direct3D-9-Spielen die Leistung und Kompatibilität verbessern können (verfügbar ab Version 11-1)."

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:13
msgid "VKD3D options"
msgstr "VKD3D-Optionen"

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:20 src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:65
msgid "Configure Direct3D 12 to Vulkan translation behavior"
msgstr "Verhalten der Direct3D-12-zu-Vulkan-Übersetzung konfigurieren"

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:26 src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-log-level.vala:21
msgid "VKD3D Logging Level"
msgstr "VKD3D-Protokollstufe"

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:29
msgid "Enable VKD3D GPUVA"
msgstr "VKD3D GPUVA aktivieren"

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:30
msgid "Enables GPU Virtual Addressing. Aligns Vulkan memory management with native DX12 behavior to improve texture streaming and stability in open-world games."
msgstr "Aktiviert GPU Virtual Addressing. Gleicht die Vulkan-Speicherverwaltung an natives DX12-Verhalten an, um Texturstreaming und Stabilität in Open-World-Spielen zu verbessern."

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:35
msgid "Enable VKD3D Shader Cache"
msgstr "VKD3D-Shader-Cache aktivieren"

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:36
msgid "Enables VKD3D's internal shader caching mechanism to minimize in-game stutter."
msgstr "Aktiviert den internen Shader-Cache-Mechanismus von VKD3D, um Ruckeln im Spiel zu minimieren."

