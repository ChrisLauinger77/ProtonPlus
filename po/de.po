msgstr "Aktiviert (erzwingen)"

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:15
msgid "Disables Next-Gen Geometry (NGG). Fixes crashes in older Vulkan games."
msgstr "Deaktiviert Next-Gen Geometry (NGG). Behebt Abstürze in älteren Vulkan-Spielen."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:16
msgid "Disables internal application binary interface caching."
msgstr "Deaktiviert das interne Caching der binären Anwendungsschnittstelle."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:17
msgid "Disables background shader compilation."
msgstr "Deaktiviert die Shader-Kompilierung im Hintergrund."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:18
msgid "Disables Delta Color Compression. Can fix specific rendering artifacts."
msgstr "Deaktiviert Delta Color Compression. Kann bestimmte Darstellungsartefakte beheben."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:19
msgid "Disables Variable Rate Shading (VRS). Fixes UI artifacts in some games."
msgstr "Deaktiviert Variable Rate Shading (VRS). Behebt UI-Artefakte in einigen Spielen."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:20
msgid "Disables Graphics Pipeline Library (GPL) to troubleshoot startup crashes."
msgstr "Deaktiviert die Graphics Pipeline Library (GPL), um Startabstürze zu untersuchen."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:21
msgid "Forces fallback command submission mode. Helps diagnosing GPU hangs."
msgstr "Erzwingt den alternativen Modus zur Befehlsübermittlung. Hilft bei der Diagnose von GPU-Hängern."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:22
msgid "Disables Vertex Runtime Shading. Can fix specific rendering artifacts."
msgstr "Deaktiviert Vertex Runtime Shading. Kann bestimmte Darstellungsartefakte beheben."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:23
msgid "Precompiles shaders during loading screens to reduce in-game stuttering."
msgstr "Kompiliert Shader während Ladebildschirmen vorab, um Ruckler im Spiel zu reduzieren."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:24
msgid "Disables AMD Texture Compression. Fixes texture glitches on APUs and Steam Deck."
msgstr "Deaktiviert AMD Texture Compression. Behebt Texturfehler auf APUs und Steam Deck."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:27
msgid "AMD RADV Debug Options"
msgstr "AMD-RADV-Debug-Optionen"

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:28
msgid "Fine-tune AMD Radeon Vulkan driver behavior"
msgstr "Verhalten des AMD-Radeon-Vulkan-Treibers feinabstimmen"

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:29
msgid "Enable RADV Debug"
msgstr "RADV-Debug aktivieren"

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:30
msgid "Apply low-level driver bugfixes and overrides"
msgstr "Low-Level-Treiberkorrekturen und Überschreibungen anwenden"

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:15
msgid "Enables experimental hardware Ray Tracing support."
msgstr "Aktiviert experimentelle Hardware-Raytracing-Unterstützung."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:16
msgid "Optimizes Smart Access Memory / Resizable BAR utilization."
msgstr "Optimiert die Nutzung von Smart Access Memory / Resizable BAR."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:17
msgid "Enables Next-Gen Geometry Culling for better geometry performance."
msgstr "Aktiviert Next-Gen Geometry Culling für bessere Geometrieleistung."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:18
msgid "Graphics Pipeline Library. Drastically reduces shader stuttering."
msgstr "Graphics Pipeline Library. Reduziert Shader-Ruckler deutlich."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:19
msgid "Enables User Space Queue submission. Can improve CPU-bound game performance on modern kernels."
msgstr "Aktiviert die User-Space-Queue-Übermittlung. Kann die Leistung CPU-limitierter Spiele auf modernen Kerneln verbessern."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:22
msgid "Emulates hardware Ray Tracing using software compute shaders on AMD GPUs. Enables RT features on unsupported hardware at the cost of a drastic performance drop."
msgstr "Emuliert Hardware-Raytracing mithilfe von Software-Compute-Shadern auf AMD-GPUs. Aktiviert RT-Funktionen auf nicht unterstützter Hardware auf Kosten eines deutlichen Leistungsabfalls."

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:26
msgid "AMD RADV Performance Tests"
msgstr "AMD-RADV-Leistungstests"

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:27
msgid "Enable experimental AMD performance features"
msgstr "Experimentelle AMD-Leistungsfunktionen aktivieren"

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:28
msgid "Enable RADV Perftest"
msgstr "RADV-Perftest aktivieren"

#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:29
msgid "Test bleeding-edge driver optimizations (use with caution)"
msgstr "Neueste Treiberoptimierungen testen (mit Vorsicht verwenden)"

#: src/widgets/games/launch-options-editor/launch-options-editor-resolution-field.vala:37
msgid "Auto detect"
msgstr "Automatische Erkennung"

#: src/widgets/games/launch-options-editor/launch-options-editor-resolution-field.vala:38 src/widgets/mangohud/mangohud-presets-page.vala:26 src/widgets/mangohud/mangohud-presets-page.vala:54
msgid "Custom"
msgstr "Benutzerdefiniert"

#: src/widgets/games/launch-options-editor/launch-options-editor-resolution-field.vala:69 src/widgets/games/launch-options-editor/launch-options-editor-spin-tile.vala:44
msgid "Set"
msgstr "Setze"

#: src/widgets/games/launch-options-editor/launch-options-editor-resolution-field.vala:70
msgid "Apply the custom resolution"
msgstr "Benutzerdefinierte Auflösung anwenden"

#: src/widgets/games/launch-options-editor/launch-options-editor-spin-tile.vala:45
msgid "Apply the FPS value"
msgstr "Den FPS-Wert anwenden"

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:32
msgid "Enables VKD3D's internal shader cache on disk. Drastically reduces micro-stuttering and speeds up consecutive loading times."
msgstr "Aktiviert den internen Shader-Cache von VKD3D auf dem Datenträger. Reduziert Mikroruckler drastisch und beschleunigt nachfolgende Ladevorgänge."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:36
msgid "Forces VKD3D to use system RAM instead of VRAM for caching shader compilation data, ensuring smoother data stream between CPU and GPU."
msgstr ""
"Erzwingt, dass VKD3D zum Zwischenspeichern von Shader-Kompilierungsdaten den Arbeitsspeicher statt des Grafikspeichers verwendet, wodurch ein gleichmäßigerer Datenfluss zwischen CPU und GPU "
"gewährleistet wird."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:38
msgid "Uses host-visible VRAM for staging buffers. Drastically reduces stuttering if Resizable BAR / SAM is enabled."
msgstr "Verwendet vom Host sichtbaren VRAM für Staging-Puffer. Reduziert Ruckeln drastisch, wenn Resizable BAR / SAM aktiviert ist."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:41
msgid "Disables host-visible VRAM staging buffers. Use as a compatibility fallback if experiencing memory-related crashes."
msgstr "Deaktiviert vom Host sichtbare VRAM-Staging-Puffer. Als Kompatibilitätsausweichlösung verwenden, wenn speicherbedingte Abstürze auftreten."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:45
msgid "Disables D3D12 Ray Tracing (DXR) capabilities entirely. Significantly improves performance and stability on GPUs without strong hardware RT support."
msgstr "Deaktiviert die D3D12-Raytracing-Fähigkeiten (DXR) vollständig. Verbessert die Leistung und Stabilität auf GPUs ohne leistungsfähige Hardware-Raytracing-Unterstützung deutlich."

#. vala-lint=line-length
#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:47
msgid "Exposes D3D12 Ray Tracing (DXR 1.1 and 1.0) capabilities to the game via Vulkan extensions."
msgstr "Stellt dem Spiel D3D12-Raytracing-Funktionen (DXR 1.1 und 1.0) über Vulkan-Erweiterungen bereit."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:48
msgid "Restricts Ray Tracing capabilities to DXR 1.0 only. Useful for older RT games that crash with DXR 1.1."
msgstr "Beschränkt die Raytracing-Funktionen auf DXR 1.0. Hilfreich für ältere RT-Spiele, die mit DXR 1.1 abstürzen."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:51
msgid "Forces Ray Tracing BVH acceleration structures to be built on the CPU instead of the GPU. Severe performance impact!"
msgstr "Zwingt die CPU statt der GPU, BVH-Beschleunigungsstrukturen für Raytracing zu erstellen. Starke Leistungseinbußen!"

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:53
msgid "Aggressively unifies memory allocators for textures and buffers to save a small amount of VRAM."
msgstr "Vereinheitlicht Speicherzuweisungen für Texturen und Puffer aggressiv, um etwas VRAM einzusparen."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:54
msgid "Enables advanced GPU Virtual Addressing to improve Direct3D 12 memory mapping in massive open-world games."
msgstr "Aktiviert die erweiterte virtuelle GPU-Adressierung, um die Direct3D-12-Speicherzuordnung in riesigen Open-World-Spielen zu verbessern."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:55
msgid "Disables descriptor caches. Workaround for specific games suffering from memory leaks."
msgstr "Deaktiviert Deskriptor-Caches. Ausweichlösung für bestimmte Spiele, bei denen Speicherlecks auftreten."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:56
msgid "Forces the GPU to maintain stable clock rates. Intended for accurate benchmarking only."
msgstr "Zwingt die GPU, stabile Taktraten beizubehalten. Nur für genaue Leistungsmessungen vorgesehen."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:59
msgid "Alters how root parameters are passed to compute shaders. Can fix specific rendering glitches."
msgstr "Ändert die Übergabe von Stammparametern an Compute-Shader. Kann bestimmte Darstellungsfehler beheben."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:61
msgid "Allows unaligned stencil buffer clears. Workaround for certain older Direct3D 12 renderers."
msgstr "Erlaubt das Löschen nicht ausgerichteter Stencil-Puffer. Ausweichlösung für bestimmte ältere Direct3D-12-Renderer."

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:64
msgid "VKD3D Proton Configurations"
msgstr "VKD3D-Proton-Konfigurationen"

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:66
msgid "Enable VKD3D Option"
msgstr "VKD3D-Option aktivieren"

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:67
msgid "Test specific Direct3D 12 compatibility workarounds and optimizations"
msgstr "Bestimmte Direct3D-12-Kompatibilitäts-Workarounds und Optimierungen testen"

#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-log-level.vala:22
msgid "Adjust how much debugging information VKD3D prints to the terminal."
msgstr "Anpassen, wie viele Debugging-Informationen VKD3D im Terminal ausgibt."

