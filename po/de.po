msgid "Disables the instruction scheduling pass. Can help isolate compiler bugs."
msgstr "Deaktiviert den Instruction-Scheduling-Durchlauf. Kann helfen, Compilerfehler einzugrenzen."

#: src/widgets/games/launch-options-editor/launch-options-editor-aco-debug.vala:20
msgid "Forces Wave64 mode execution on RDNA hardware instead of the default Wave32."
msgstr "Erzwingt die Ausführung im Wave64-Modus auf RDNA-Hardware statt des Standardmodus Wave32."

